#!/usr/bin/env bash

[[ -z $MPVD_SOCK ]] && export MPVD_SOCK="${XDG_RUNTIME_DIR:-$HOME}/mpvd.sock"
[[ -z $MPVD_PID ]] && export MPVD_PID="${MPVD_SOCK%/*}/mpvd.pid"

mpvctl() {
  mpvctl-"${1:-init}" "${@:2}"
}

mpvctl-help() {
  echo 'Usage: mpvctl [command=init] [args...]'
  echo
  echo 'Commands:'
  echo '  help                  Print this help message'
  echo '  version               Print mpvctl and mpv versions'
  echo '  init                  Spawn mpv process or list running one'
  echo '  stat                  List running mpv process'
  echo '  kill                  Kill running mpv process'
  echo '  push <file...>        Push files to playlist'
  echo '  play [index]          Start playback'
  echo '  stop                  Stop playback'
  echo '  next                  Go to next file'
  echo '  prev                  Go to previous file'
  echo '  move <from> <to>      Move file in playlist'
  echo '  remove <index>        Remove file at index from playlist'
  echo '  pick [count=10]       Pick songs from random selection of count'
  echo '  list                  Print playlist state'
  echo '  time                  Print time position of current track'
  echo '  position              Print playlist position of current track'
  echo '  state                 Print playing/paused state'
  echo
  echo 'Internal Commands:'
  echo '  send <cmd> [args...]  Send IPC command'
  echo '  mesg <cmd> [args...]  Print IPC JSON message'
  echo '  sock                  Print IPC socket path'
}
mpvctl--h() { mpvctl-help; }
mpvctl---help() { mpvctl-help; }

mpvctl-version() {
  echo "mpvctl v1.0.0"
  mpv --version | head -n1 | cut -f1,2 -d' '
}
mpvctl--V() { mpvctl-version; }
mpvctl---version() { mpvctl-version; }

mpvctl-init() {
  if mpvctl-stat; then return; fi
  nohup "$(which mpv)" --idle --no-video --input-ipc-server="$MPVD_SOCK" >/dev/null 2>&1 &
  echo $! > "$MPVD_PID"
  sleep .1
  mpvctl-stat
}

mpvctl-stat() {
  [[ -f $MPVD_PID ]] && pgrep -aF "$MPVD_PID"
}
mpvctl-kill() {
  local e=0
  [[ -f $MPVD_PID ]] && kill ${*:--9} "$(cat "$MPVD_PID")"
  if [[ $? != 0 ]]; then e=1; fi
  rm -f "$MPVD_SOCK"
  rm -f "$MPVD_PID"
  return $e
}

mpvctl-push() {
  mpvctl-init >/dev/null
  mpvctl-send loadfile "$1" append-play
  shift; if [[ $# -gt 0 ]]; then mpvctl-push "$@"; fi
}
mpvctl-play() {
  if [[ -n $1 ]]; then mpvctl-send playlist-play-index $(($1-1)); fi
  mpvctl-send set_property_string pause no
}
mpvctl-stop() { mpvctl-send set_property_string pause yes; }
mpvctl-next() { mpvctl-send playlist-next; }
mpvctl-previous() { mpvctl-send playlist-prev; }
mpvctl-prev() { mpvctl-previous; }
mpvctl-move() {
  if [[ $1 == $2 ]]
  then return
  elif [[ $1 -lt $2 ]]
  then mpvctl-send playlist-move $(($1-1)) $2
  elif [[ $1 -gt $2 ]]
  then mpvctl-send playlist-move $(($1-1)) $(($2-1))
  fi
}
mpvctl-mv() { mpvctl-move "$@"; }
mpvctl-remove() { mpvctl-send playlist-remove $(($1-1)); }
mpvctl-rm() { mpvctl-remove "$@"; }

mpvctl-pick() {
  mpvctl-init >/dev/null
  local count=${1:-10}
  local select=$(find -L "$HOME/Music" -maxdepth 2 -iname \*.mp3 | sort -R | head -n "$count")
  echo "$select" \
    | sed "s|^$HOME/Music/||" \
    | fzf -m --no-input --height "$count" --layout reverse \
    | while read -r f; do mpvctl-push "$HOME/Music/$f"; done
}

mpvctl-list() {
  local f='(.filename | match("[^/]*$") | .string)'
  if [[ ! -t 1 ]]
  then mpvctl-send get_property playlist | jq -r ".data|map($f)[]"
  else
    local hl_start='\u001b[32m'
    local hl_end='\u001b[m'
    local playlist=$(mpvctl-send get_property playlist)
    local pause=$(mpvctl-send get_property pause | jq .data)
    local cursor=$([[ $pause = false ]] && echo \* || echo -)
    local b="if .current then \"$cursor $hl_start\" else \"  \" end"
    local e="if .current then \"$hl_end\" else \"\" end"
    echo "$playlist" | jq -r ".data|map($b+$f+$e)[]" | bat -n
  fi
}
mpvctl-ls() { mpvctl-list; }

mpvctl-time() {
  local pos=$(mpvctl-send get_property time-pos | jq .data)
  local pos_secs=${pos%%.*}
  local dur=$(mpvctl-send get_property duration | jq .data)
  local dur_secs=${dur%%.*}
  printf '%02d:%02d/%02d:%02d\n' \
    $((pos_secs/60)) $((pos_secs%60)) \
    $((dur_secs/60)) $((dur_secs%60)) \
    2>/dev/null
}

mpvctl-position() {
  local pos=$(mpvctl-send get_property playlist-pos | jq .data)
  echo $((pos+1))
}
mpvctl-pos() { mpvctl-position; }

mpvctl-state() {
  local pause=$(mpvctl-send get_property pause | jq .data)
  if [[ $pause == true ]]
  then echo paused
  else echo playing
  fi
}

mpvctl-send() { mpvctl-mesg "$@" | socat - "$MPVD_SOCK"; }

mpvctl-mesg() {
  local v; printf '{"command":['
  while v=$1; shift; do
  if [[ $v =~ ^[-+]?[0-9]+(\.[0-9]+)?$ ]]
  then printf %s "$v"; else printf '"%s"' "$v"; fi
  if [[ $# -gt 0 ]]; then printf ,; fi; done
  echo ']}'
}

mpvctl-sock() {
  echo "$MPVD_SOCK"
  [[ -e $MPVD_SOCK ]]
  return $?
}

[[ $0 == *sh* ]] || mpvctl "$@"
