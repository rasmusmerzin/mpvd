{
  "name": "@merzin/mpvd",
  "version": "0.2.0",
  "description": "MPV music player daemon",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rasmusmerzin/mpvctl.git"
  },
  "keywords": [
    "mpv",
    "mpvd",
    "mpvctl"
  ],
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "bin": {
    "mpvctl": "bin/mpvctl",
    "mpvd": "bin/mpvd.js"
  },
  "files": [
    "lib",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "15",
    "ink": "7",
    "react": "19"
  },
  "devDependencies": {
    "@types/ink": "^0.5.2",
    "@types/react": "19",
    "@types/node": "25",
    "prettier": "3",
    "typescript": "6.0"
  }
}
